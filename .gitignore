# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl
pip-wheel-metadata/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
.env
ENV/

# ── Jupyter ────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/
profile_default/
ipython_config.py

# ── Generated output ───────────────────────────────────────────────────────────
output/
# Keep the output directory itself tracked but ignore its contents
!output/.gitkeep

# ── OS files ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

